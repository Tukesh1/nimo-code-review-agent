# GitHub token is always required to fetch PR diffs and post comments
GITHUB_TOKEN="put your GitHub token here"

# Choose your provider: 'gemini', 'openai', 'claude', or 'openrouter'
AI_PROVIDER=openrouter
AI_MODEL=qwen/qwen-2.5-coder-32b-instruct

# Provide the key for the provider you selected above
# OPENAI_API_KEY=sk-your-openai-key
# GEMINI_API_KEY="put your GEMINI API key here"
# CLAUDE_API_KEY=your_claude_key
OPENROUTER_API_KEY=your_openrouter_key
